{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "types": ["svelte", "vite/client"]
  },
  "include": ["frontend/src/**/*", "vite.config.ts"]
}
